server {
    listen 80;
    server_name {{ ansible_host }} {{ url }};
    return 301 https://$host$request_uri;
}

server {
    listen {{ ssl_port }} ssl;
    server_name {{ ansible_host }} {{ url }};

    ssl_certificate {{ nginx_ssl_dir }}/fullchain.pem;
    ssl_certificate_key {{ nginx_ssl_dir }}/boyaca-key.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    client_max_body_size 10G;
    proxy_send_timeout 120;
    proxy_read_timeout 300;
    proxy_buffering    off;
    proxy_request_buffering off;
    keepalive_timeout  5 5;
    tcp_nodelay        on;

    location / {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto "https";
        proxy_set_header X-Forwarded-Port {{ ssl_port }};
    }
}

server {
    listen {{ docker_ssl_port }} ssl;
    server_name {{ ansible_host }} {{ url }};

    ssl_certificate {{ nginx_ssl_dir }}/fullchain.pem;
    ssl_certificate_key {{ nginx_ssl_dir }}/boyaca-key.pem;
    
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;

    client_max_body_size 10G;
    proxy_send_timeout 120;
    proxy_read_timeout 300;
    proxy_buffering off;
    proxy_request_buffering off;

    location / {
        proxy_pass http://127.0.0.1:{{ nexus_docker_http_port }};
        proxy_set_header Host $host:$server_port;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto "https";
    }
}
