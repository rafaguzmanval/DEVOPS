# Jenkins Configuration as Code - Credentials
# Managed by Ansible - Do not edit manually

credentials:
  system:
    domainCredentials:
      - credentials:
{% for cred in additional_credentials | default([]) %}
{% for type, props in cred.items() %}
          - {{ type }}:
{% for key, value in props.items() %}
              {{ key }}: "{{ value }}"
{% endfor %}
{% endfor %}
{% endfor %}
